---
import { site, waLink } from "../data/site";
import WhatsAppIcon from "./WhatsAppIcon.astro";
---
<header class="hero" id="top">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__scrim" aria-hidden="true"></div>
  <div class="hero__inner container">
    <p class="hero__eyebrow reveal is-in">{site.eyebrow}</p>
    <h1 class="hero__wordmark reveal is-in">{site.brand}</h1>
    <p class="hero__tagline reveal is-in">{site.tagline}</p>
    <div class="hero__cta reveal is-in">
      <a class="btn btn--dark" href="#catalogo" data-scroll="#catalogo">Nuestras Tartas</a>
      <a
        class="btn btn--gold"
        href={waLink()}
        target="_blank"
        rel="noopener"
      >
        <WhatsAppIcon size={18} />
        Haz tu pedido ya
      </a>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: clamp(560px, 84vh, 880px);
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    /* Hero photo from the final Home Page frame.
       hero-cream.jpg stays as a fallback layer underneath. */
    background-image: url("/images/hero-photo.jpg"), url("/images/hero-cream.jpg");
    background-size: cover;
    background-position: center;
    transform: scale(1.04);           /* room for a subtle drift, GPU only */
    animation: heroDrift 22s ease-in-out infinite alternate;
  }
  /* Soft cream glow behind the wordmark so the dark logo stays legible
     on a bright photo — lightens, never darkens the image. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to right,
      rgba(255, 250, 244, 0.62) 0%,
      rgba(255, 250, 244, 0.28) 46%,
      rgba(255, 250, 244, 0) 72%
    );
  }
  @keyframes heroDrift {
    from { transform: scale(1.04) translate3d(0, 0, 0); }
    to   { transform: scale(1.08) translate3d(0, -1.4%, 0); }
  }
  .hero__inner {
    padding-inline: clamp(20px, 7.6vw, 110px);
    max-width: none;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }
  .hero__eyebrow {
    font-size: clamp(0.72rem, 1.1vw, 0.95rem);
    letter-spacing: 0.22em;
    color: var(--brown);
    font-weight: 300;
    margin-bottom: 0.5rem;
  }
  .hero__wordmark {
    font-family: var(--font-logo);
    font-weight: 400;                 /* Krona One ships a single weight */
    color: var(--brown);
    font-size: clamp(2.6rem, 8.2vw, 7rem);
    letter-spacing: 0.02em;           /* Krona One is already wide by design */
    line-height: 1;
    max-width: 100%;
    overflow-wrap: normal;
  }
  .hero__tagline {
    margin-top: 0.4rem;
    font-size: clamp(0.72rem, 1.3vw, 0.9rem);
    letter-spacing: 0.28em;
    color: var(--brown);
    font-weight: 300;
  }
  .hero__cta {
    margin-top: clamp(1.6rem, 4vw, 2.8rem);
    display: flex;
    gap: clamp(12px, 2.8vw, 40px);
    flex-wrap: wrap;
    justify-content: flex-start;
  }
  .hero__cta .btn { width: 300px; max-width: 100%; }

  /* stagger the load reveals */
  .hero__wordmark { animation-delay: 0.05s; }
  .hero__tagline  { animation-delay: 0.18s; }
  .hero__cta      { animation-delay: 0.3s; }

  @media (max-width: 640px) {
    /* MOBILE frame: photo band on top, text + buttons on a light block below */
    .hero {
      min-height: auto;
      display: block;
      background: var(--cream-hero);
    }
    .hero__bg {
      position: relative;
      inset: auto;
      z-index: auto;
      height: min(56vh, 440px);
      transform: none;
      animation: none;
    }
    .hero__scrim { display: none; }
    .hero__inner {
      align-items: stretch;
      padding-block: 24px 30px;
    }
    .hero__wordmark { font-size: clamp(2.6rem, 15vw, 4rem); }
    .hero__cta {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
      margin-top: 22px;
    }
    .hero__cta .btn { width: 100%; height: 46px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__bg { animation: none; transform: none; }
  }
</style>
