---
import { site, heroImage } from "../data/site";
---
<header class="hero" id="top">
  <div class="hero__media" aria-hidden="true">
    <div class="hero__bg"></div>
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>
  <div class="hero__inner container">
    <p class="hero__eyebrow hero-in">{site.eyebrow}</p>
    <h1 class="hero__wordmark hero-in">{site.brand}</h1>
    <p class="hero__tagline hero-in">{site.tagline}</p>
  </div>
</header>

<style define:vars={{ heroImage: `url("${heroImage}")` }}>
  /* ── shell ──────────────────────────────────────────────
     Photograph is the background at EVERY breakpoint; the
     text is overlaid on top of it (never stacked below).   */
  .hero {
    position: relative;
    min-height: clamp(640px, 90vh, 960px);
    min-height: clamp(640px, 90svh, 960px);
    display: grid;
    place-items: center;
    padding-block: clamp(56px, 9vh, 116px) clamp(88px, 14vh, 172px);
    overflow: hidden;
    isolation: isolate;
  }

  /* Parallax layer. Kept separate from .hero__bg so the scroll
     transform never competes with the intro scale animation.
     Vertical slack (-7%) means the drift can never expose an edge. */
  .hero__media {
    position: absolute;
    inset: -7% 0;
    z-index: -2;
    will-change: transform;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    /* Single hero asset — path comes from src/data/site.ts.
       Swap public/images/hero.jpg to change it; no code edits. */
    background-image: var(--heroImage);
    background-size: cover;
    background-position: center;
    transform: scale(1.05);
    transform-origin: center;
    will-change: transform, opacity;
    animation: heroIntro 6s cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }

  /* Soft cream veil so the dark logo stays legible on a bright photo. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to right,
      rgba(255, 250, 244, 0.62) 0%,
      rgba(255, 250, 244, 0.28) 46%,
      rgba(255, 250, 244, 0) 72%
    );
  }

  /* The photograph ends on a clean, defined edge — the Services
     section begins immediately below it. No blending between them. */

  /* ── content ────────────────────────────────────────── */
  .hero__inner {
    padding-inline: clamp(20px, 7.6vw, 110px);
    max-width: none;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }
  .hero__eyebrow {
    font-size: clamp(0.72rem, 1.1vw, 0.95rem);
    letter-spacing: 0.22em;
    color: var(--brown);
    font-weight: 300;
    margin-bottom: 0.62rem;
  }
  .hero__wordmark {
    font-family: var(--font-logo);
    font-weight: 400;                 /* Krona One ships a single weight */
    color: var(--brown);
    font-size: clamp(2.76rem, 8.7vw, 7.42rem);
    letter-spacing: 0.02em;
    line-height: 1;
    max-width: 100%;
    overflow-wrap: normal;
  }
  .hero__tagline {
    margin-top: 0.5rem;
    font-size: clamp(0.72rem, 1.3vw, 0.9rem);
    letter-spacing: 0.28em;
    color: var(--brown);
    font-weight: 300;
  }

  /* ── entrance ──────────────────────────────────────── */
  @keyframes heroIntro {
    0%   { opacity: 0; transform: scale(1.05); }
    35%  { opacity: 1; }
    100% { opacity: 1; transform: scale(1); }
  }
  /* Restrained parallax: the photograph drifts at roughly a sixth
     of scroll speed. Where scroll-driven animations are supported
     this runs entirely on the compositor — no JS, no scroll handler. */
  @keyframes heroParallax {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(0, 6%, 0); }
  }
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: scroll()) {
      .hero__media {
        animation: heroParallax linear both;
        animation-timeline: scroll(root block);
        animation-range: 0 100vh;
      }
    }
  }

  @keyframes heroRise {
    from { opacity: 0; transform: translate3d(0, 14px, 0); }
    to   { opacity: 1; transform: translate3d(0, 0, 0); }
  }
  .hero-in {
    opacity: 0;
    will-change: transform, opacity;
    animation: heroRise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__eyebrow.hero-in  { animation-delay: 0.15s; }
  .hero__wordmark.hero-in { animation-delay: 0.30s; }
  .hero__tagline.hero-in  { animation-delay: 0.45s; }

  /* ── mobile ────────────────────────────────────────────
     Same overlay structure as desktop — only the height and
     the veil direction change. Frame: photo band 0–569.    */
  @media (max-width: 640px) {
    /* The photograph owns the first screen: the hero fills almost the
       whole viewport, so Services only appears once the user scrolls. */
    .hero {
      min-height: 92vh;
      min-height: 92svh;
      /* content is anchored in the lower half rather than centred */
      place-items: end start;
      padding-block: clamp(40px, 8vh, 72px) clamp(72px, 14vh, 132px);
    }

    /* Veil peaks behind the type and eases off again before the
       bottom, so the image keeps its density right up to the edge. */
    .hero__scrim {
      background: linear-gradient(
        to bottom,
        rgba(255, 250, 244, 0) 0%,
        rgba(255, 250, 244, 0.1) 46%,
        rgba(255, 250, 244, 0.42) 80%,
        rgba(255, 250, 244, 0.12) 100%
      );
    }

    /* Type sits directly on the photograph now, so a barely-visible
       cream halo keeps it crisp over crumbs and shadows without
       lightening the image itself. */
    .hero__eyebrow,
    .hero__wordmark,
    .hero__tagline {
      text-shadow: 0 1px 14px rgba(255, 250, 244, 0.62);
    }

    .hero__wordmark { font-size: clamp(2.76rem, 15.9vw, 4.24rem); }
  }

  /* ── reduced motion ────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero__media,
    .hero__bg,
    .hero-in {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Parallax fallback for browsers without scroll-driven CSS animations
  // (Safari, Firefox). Chromium handles it on the compositor via the
  // @supports block above, so this never runs there.
  const media = document.querySelector<HTMLElement>(".hero__media");
  const hero = document.querySelector<HTMLElement>(".hero");

  const supportsScrollTimeline =
    typeof CSS !== "undefined" && CSS.supports("animation-timeline: scroll()");

  if (media && hero && !supportsScrollTimeline) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    let visible = true;
    let ticking = false;

    const update = () => {
      ticking = false;
      if (reduce.matches || !visible) return;
      const h = hero.offsetHeight || 1;
      // 0 → 1 across the first screenful, then clamp
      const progress = Math.min(Math.max(window.scrollY / h, 0), 1);
      media.style.transform = `translate3d(0, ${(progress * 6).toFixed(3)}%, 0)`;
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    // Only listen while the hero is actually on screen.
    if ("IntersectionObserver" in window) {
      new IntersectionObserver(
        ([entry]) => {
          visible = entry.isIntersecting;
        },
        { rootMargin: "10% 0px" }
      ).observe(hero);
    }

    const enable = () => {
      if (reduce.matches) {
        media.style.transform = "";
        window.removeEventListener("scroll", onScroll);
      } else {
        window.addEventListener("scroll", onScroll, { passive: true });
        update();
      }
    };

    enable();
    reduce.addEventListener?.("change", enable);
  }
</script>
