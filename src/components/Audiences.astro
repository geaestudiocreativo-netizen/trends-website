---
// SERVICES section — row accordion ("Para ti", "Restaurantes", "Eventos").
// Only this section was updated. One row open at a time; opening one closes
// the others. Whole row is the tap/click target (label, icon or empty space).
import { audiences } from "../data/audiences";
import { waLink } from "../data/site";
import WhatsAppIcon from "./WhatsAppIcon.astro";
---
<section class="section audiences-section" aria-labelledby="audiences-title">
  <div class="container audiences">
    <div class="audiences__intro reveal">
      <h2 class="section-title" id="audiences-title">Para<br />quiénes</h2>
      <p class="eyebrow audiences__sub">Siempre para<br />todos.</p>
    </div>

    <ul class="audiences__list" data-accordion="audiences">
      {audiences.map((a, i) => (
        <li class="aud" data-aud data-aud-index={i}>
          <button
            class="aud__head"
            aria-expanded="false"
            aria-controls={`panel-${a.id}`}
            id={`btn-${a.id}`}
          >
            <span class="aud__label">{a.label}</span>
            <span class="aud__icon" aria-hidden="true">
              <span class="aud__bar aud__bar--h"></span>
              <span class="aud__bar aud__bar--v"></span>
            </span>
          </button>

          <div class="aud__panel" id={`panel-${a.id}`} role="region" aria-labelledby={`btn-${a.id}`}>
            <div class="aud__panel-inner">
              <p class="aud__detail">{a.detail}</p>
              <a class="btn btn--gold aud__cta" href={waLink(a.cta)} target="_blank" rel="noopener">
                <WhatsAppIcon size={17} /> Pedir por WhatsApp
              </a>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* --- unchanged section shell (bg, layout grid) --- */
  .audiences-section {
    background: var(--white);
    --svc-dur: 0.4s;
    --svc-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --aud-title-dur: 450ms;
    --aud-title-gap: 180ms;
  }
  .audiences {
    display: grid;
    grid-template-columns: minmax(160px, 240px) 1fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: start;
  }
  .audiences__intro .section-title { line-height: 1.05; }
  .audiences__sub { margin-top: 1rem; line-height: 1.5; }

  /* --- accordion rows (Services) --- */
  .audiences__list { border-top: 1px solid var(--hairline); }
  .aud { border-bottom: 1px solid var(--hairline); }

  .aud__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;                          /* whole row is the tap target */
    text-align: left;
    padding: clamp(18px, 3.2vw, 26px) 2px;
    cursor: pointer;
    transition: transform 150ms var(--svc-ease);
  }
  .aud__head:active { transform: scale(0.97); }
  .aud__label {
    font-size: clamp(1.15rem, 2.4vw, 1.5rem);
    font-weight: 500;
    color: var(--brown);
    letter-spacing: 0.02em;
    line-height: 1.1;
    opacity: 0;
    transform: translate3d(-40px, 0, 0);
  }
  .audiences-section.is-animated .aud__label {
    animation: audTitleIn var(--aud-title-dur) var(--svc-ease) forwards;
  }
  .audiences-section.is-animated .aud[data-aud-index="0"] .aud__label { animation-delay: 0ms; }
  .audiences-section.is-animated .aud[data-aud-index="1"] .aud__label {
    animation-delay: calc(var(--aud-title-dur) + var(--aud-title-gap));
  }
  .audiences-section.is-animated .aud[data-aud-index="2"] .aud__label {
    animation-delay: calc((var(--aud-title-dur) + var(--aud-title-gap)) * 2);
  }

  @keyframes audTitleIn {
    to { opacity: 1; transform: translate3d(0, 0, 0); }
  }
  @keyframes audFadeIn {
    to { opacity: 1; }
  }

  /* Icon fades in right after its title lands */
  .aud__icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex: none;
    opacity: 0;
  }
  .audiences-section.is-animated .aud__icon {
    animation: audFadeIn 300ms var(--svc-ease) forwards;
  }
  .audiences-section.is-animated .aud[data-aud-index="0"] .aud__icon { animation-delay: var(--aud-title-dur); }
  .audiences-section.is-animated .aud[data-aud-index="1"] .aud__icon {
    animation-delay: calc((var(--aud-title-dur) + var(--aud-title-gap)) + var(--aud-title-dur));
  }
  .audiences-section.is-animated .aud[data-aud-index="2"] .aud__icon {
    animation-delay: calc(((var(--aud-title-dur) + var(--aud-title-gap)) * 2) + var(--aud-title-dur));
  }
  .aud__bar {
    position: absolute;
    background: var(--brown);
    border-radius: 2px;
  }
  .aud__bar--h { top: 50%; left: 0; width: 100%; height: 2px; transform: translateY(-50%); }
  .aud__bar--v {
    left: 50%; top: 0; width: 2px; height: 100%;
    transform: translateX(-50%);
    transition: transform var(--svc-dur) var(--svc-ease);
    will-change: transform;
  }
  .aud__head[aria-expanded="true"] .aud__bar--v { transform: translateX(-50%) rotate(90deg); }

  /* smooth height via grid-rows; content fades + lifts slightly */
  .aud__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--svc-dur) var(--svc-ease);
  }
  .aud__panel-inner {
    overflow: hidden;
    opacity: 0;
    transform: translate3d(0, 12px, 0);
    transition:
      opacity var(--svc-dur) var(--svc-ease),
      transform var(--svc-dur) var(--svc-ease);
  }
  .aud__head[aria-expanded="true"] + .aud__panel { grid-template-rows: 1fr; }
  .aud__head[aria-expanded="true"] + .aud__panel .aud__panel-inner {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .aud__detail {
    padding: 0 2px 4px;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 62ch;
  }
  .aud__cta {
    margin: 14px 2px 22px;
    height: 44px;
    font-size: 0.9rem;
    opacity: 0;
    transition: opacity var(--svc-dur) var(--svc-ease);
  }
  .aud__head[aria-expanded="true"] + .aud__panel .aud__cta {
    opacity: 1;
    transition-delay: 120ms;
  }

  @media (max-width: 820px) {
    .audiences { grid-template-columns: 1fr; }
    .audiences__intro .section-title br,
    .audiences__sub br { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .aud__panel, .aud__panel-inner, .aud__bar--v, .aud__cta { transition: none; }
    .aud__label, .aud__icon { opacity: 1; transform: none; animation: none; }
    .aud__head:active { transform: none; }
    .aud__head[aria-expanded="true"] + .aud__panel .aud__cta { opacity: 1; }
  }
</style>

<script>
  // Cinematic title sequence — runs once when the section enters the viewport.
  const audSection = document.querySelector<HTMLElement>(".audiences-section");
  if (audSection) {
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      audSection.classList.add("is-animated");
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              audSection.classList.add("is-animated");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.18, rootMargin: "0px 0px -6% 0px" }
      );
      io.observe(audSection);
    }
  }

  // One open at a time; opening a row closes the others. Keyboard-native (<button>).
  document.querySelectorAll<HTMLElement>('[data-accordion="audiences"]').forEach((group) => {
    const heads = Array.from(group.querySelectorAll<HTMLButtonElement>(".aud__head"));
    heads.forEach((head) => {
      head.addEventListener("click", () => {
        const isOpen = head.getAttribute("aria-expanded") === "true";
        heads.forEach((h) => h.setAttribute("aria-expanded", "false"));
        head.setAttribute("aria-expanded", isOpen ? "false" : "true");
      });
    });
  });
</script>
