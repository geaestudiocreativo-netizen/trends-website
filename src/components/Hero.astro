---
import { site } from "../data/site";

const heroTagline = "BY GABRIEL GARCÍA";
---
<header class="hero" id="top">
  <div class="hero__media" aria-hidden="true">
    <img
      class="hero__img"
      src="/images/hero.jpg"
      alt=""
      fetchpriority="high"
      decoding="async"
    />
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>
  <div class="hero__inner container">
    <h1 class="hero__wordmark hero-in">{site.brand}</h1>
    <p class="hero__tagline hero-in">{heroTagline}</p>
  </div>
</header>

<style>
  /* ── shell ──────────────────────────────────────────────
     Photograph is the background at EVERY breakpoint; the
     text is overlaid on top of it (never stacked below).   */
  .hero {
    position: relative;
    /* Clean loading state: flat brand cream shows until the photograph
       paints. No JS, no animation — just the section's own colour. */
    background-color: var(--cream-hero);
    /* Clean base while the photograph loads — flat colour, no old content. */
    background-color: var(--cream-hero);
    overflow: hidden;
    isolation: isolate;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  /* Parallax layer. Kept separate from .hero__bg so the scroll
     transform never competes with the intro scale animation.
     Vertical slack (-7%) means the drift can never expose an edge. */
  .hero__media {
    position: absolute;
    inset: 0;
    height: 100%;
    z-index: 0;
    will-change: opacity;
  }
  /* Single hero asset — src comes from src/data/site.ts.
     Swap public/images/hero.jpg to change it; no code edits.
     A content fingerprint on the URL (see site.ts) is what prevents a
     stale cached bitmap, so visibility never depends on JavaScript. */
  .hero__img {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: none;
    transform-origin: center;
    will-change: transform, opacity;
    animation: heroIntro 6s cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }

  /* Soft cream veil so the dark logo stays legible on a bright photo. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(255, 250, 244, 0.04) 0%,
      rgba(255, 250, 244, 0.1) 52%,
      rgba(255, 250, 244, 0.18) 100%
    );
  }

  /* The photograph ends on a clean, defined edge — the Services
     section begins immediately below it. No blending between them. */

  /* ── content ────────────────────────────────────────── */
  .hero__inner {
    position: absolute;
    inset: 0;
    z-index: 2;
    padding-inline: clamp(20px, 7.6vw, 110px);
    padding-top: clamp(48px, 8.6vh, 120px);
    max-width: none;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    width: 100%;
    transform: translateY(-18%);
  }
  .hero__eyebrow {
    font-size: clamp(0.72rem, 1.1vw, 0.95rem);
    letter-spacing: 0.22em;
    color: var(--brown);
    font-weight: 300;
    margin-top: clamp(1rem, 1.8vh, 1.45rem);
    margin-bottom: clamp(0.95rem, 1.7vh, 1.25rem);
  }
  .hero__wordmark {
    font-family: var(--font-logo);
    font-weight: 400;                 /* Krona One ships a single weight */
    color: var(--brown);
    align-self: center;
    text-align: center;
    margin-top: 0;
    font-size: clamp(2.76rem, 8.7vw, 7.42rem);
    letter-spacing: 0.02em;
    line-height: 1;
    max-width: 100%;
    overflow-wrap: normal;
  }
  .hero__tagline {
    align-self: center;
    text-align: center;
    margin-top: 0;
    font-size: clamp(0.72rem, 1.3vw, 0.9rem);
    letter-spacing: 0.38em;
    color: var(--brown);
    font-weight: 300;
    text-transform: uppercase;
  }

  /* ── entrance ──────────────────────────────────────── */
  @keyframes heroIntro {
    0%   { opacity: 0; transform: none; }
    35%  { opacity: 1; }
    100% { opacity: 1; transform: none; }
  }

  @keyframes heroRise {
    from { opacity: 0; transform: translate3d(0, 14px, 0); }
    to   { opacity: 1; transform: translate3d(0, 0, 0); }
  }
  .hero-in {
    will-change: transform, opacity;
    animation: heroRise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__eyebrow.hero-in  { animation-delay: 0.15s; }
  .hero__wordmark.hero-in { animation-delay: 0.30s; }
  .hero__tagline.hero-in  { animation-delay: 0.45s; }

  /* ── mobile ────────────────────────────────────────────
     Same overlay structure as desktop — only the height and
     the veil direction change. Frame: photo band 0–569.    */
  @media (max-width: 640px) {
    .hero {
      aspect-ratio: auto;
      min-height: 92vh;
      min-height: 92svh;
    }

    .hero__media {
      height: 100%;
    }

    .hero__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 42% center;
      transform: scale(-1.06, 1.06);
      animation: heroIntroMobile 6s cubic-bezier(0.22, 0.61, 0.36, 1) both;
    }

    /* Veil peaks behind the type and eases off again before the
       bottom, so the image keeps its density right up to the edge. */
    .hero__scrim {
      background: linear-gradient(
        to bottom,
        rgba(255, 250, 244, 0.02) 0%,
        rgba(255, 250, 244, 0.08) 58%,
        rgba(255, 250, 244, 0.16) 100%
      );
    }

    /* Type sits directly on the photograph now, so a barely-visible
       cream halo keeps it crisp over crumbs and shadows without
       lightening the image itself. */
    .hero__eyebrow,
    .hero__wordmark,
    .hero__tagline {
      text-shadow: 0 1px 14px rgba(255, 250, 244, 0.62);
    }

    .hero__inner {
      text-align: left;
      align-items: flex-start;
      padding-top: clamp(34px, 8.4vh, 72px);
    }

    .hero__wordmark { font-size: clamp(2.76rem, 15.9vw, 4.24rem); }
  }

  @media (min-width: 1024px) {
    .hero__inner {
      padding-left: var(--gutter);
    }

    .hero__media {
      transform: scaleX(-1);
      transform-origin: center;
    }
  }

  @keyframes heroIntroMobile {
    0%   { opacity: 0; transform: scale(-1.1, 1.1); }
    35%  { opacity: 1; }
    100% { opacity: 1; transform: scale(-1.06, 1.06); }
  }

  /* ── reduced motion ────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero__img,
    .hero-in {
      animation: none;
      opacity: 1;
    }
    .hero-in {
      transform: none;
    }
  }
</style>
