---
import { SIZE_CATALOG } from "../data/cakes";
import type { Cake } from "../data/cakes";
import { allergenById } from "../data/allergens";
import { site, waLink } from "../data/site";
import WhatsAppIcon from "./WhatsAppIcon.astro";

interface Props { cake: Cake; }
const { cake } = Astro.props;
const sizes = cake.sizes.map((code) => SIZE_CATALOG[code]).filter(Boolean);
const collapsedSizes = sizes.filter((size) => size.code !== "L");
const allergenNames = cake.allergens.map((id) => allergenById[id]?.name).filter(Boolean);
const orderMsg = site.whatsappItemMessage.replace("{item}", cake.title);
---
<article class="card" data-card data-categories={cake.categories.join(" ")}>
  <button
    class="card__head"
    aria-expanded="false"
    aria-controls={`panel-${cake.id}`}
    id={`btn-${cake.id}`}
  >
    <span class="card__media">
      <img src={cake.image} alt={cake.alt} width="339" height="366" loading="lazy" decoding="async" />
      <span class="card__price">{cake.price}</span>
    </span>

    <span class="card__body">
      <span class="card__title-row">
        <span class="card__title">{cake.title}</span>
      </span>
      <span class="card__desc">{cake.description}</span>
      <span class="card__sub">{cake.subline}</span>
      <span class="card__bottom-row">
        <span class="card__sizes" role="list" aria-label="Tamaños disponibles">
          {collapsedSizes.map((s) => (
            <span class="size-chip" role="listitem" title={s.code === "S" ? "15 cm" : "22 cm"} style={`--bg:${s.code === "S" ? "#A49250" : "#8AC3BE"};--fg:${s.code === "S" ? "#574D29" : "#567B77"}`}>{s.code === "S" ? "15 cm" : "22 cm"}</span>
          ))}
        </span>
        <span class="card__details">Ver detalles <span class="card__details-arrow" aria-hidden="true">→</span></span>
      </span>
    </span>
  </button>

  <div class="card__panel" id={`panel-${cake.id}`} role="region" aria-labelledby={`btn-${cake.id}`}>
    <div class="card__panel-inner">
      <div class="detail">
        <h4 class="detail__h">Tamaños y precios</h4>
        <ul class="sizes">
          {sizes.map((s) => (
            <li class="size">
              <span class="size__label">
                <span class="size__code" style={`--bg:${s.bg};--fg:${s.fg}`}>{s.code}</span>
                {s.name}<em class="size__note">{s.note}</em>
              </span>
              <span class="size__price">{s.price}</span>
            </li>
          ))}
        </ul>

        <h4 class="detail__h">Alérgenos</h4>
        <p class="detail__allergens">{allergenNames.join(" · ")}</p>

        <h4 class="detail__h">Conservación</h4>
        <p class="detail__storage">{cake.storage}</p>

        <a class="btn btn--gold detail__cta" href={waLink(orderMsg)} target="_blank" rel="noopener">
          <WhatsAppIcon size={17} /> Pedir esta tarta
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  .card {
    height: 100%;
    display: flex;
    flex-direction: column;
    background: var(--cream-hero);
    border-radius: var(--radius-card);
    box-shadow: var(--card-shadow);
    overflow: hidden;
    transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
    will-change: transform;
  }
  .card:hover { transform: translateY(-4px); box-shadow: var(--card-shadow-hover); }
  .card:focus-within { box-shadow: var(--card-shadow-hover); }

  .card__head {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    width: 100%;
    text-align: left;
    padding: 13px 10.5px 0;
  }

  .card__media {
    position: relative;
    display: block;
    aspect-ratio: 339 / 366;
    border-radius: var(--radius-card);
    overflow: hidden;
  }
  .card__media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s var(--ease);
    will-change: transform;
  }
  .card:hover .card__media img { transform: scale(1.05); }
  .card__price {
    position: absolute; top: 0; right: 0;
    background: var(--brown);
    color: var(--cream-hero);
    font-size: 0.76rem; font-weight: 500;
    padding: 6px 14px;
    border-radius: 0 var(--radius-card) 0 10px;
  }
  .card__price::before { content: "desde "; }

  .card__body {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    padding: 17px 2px 11px;
  }
  .card__title-row {
    display: flex;
    min-height: 2.816rem;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .card__title {
    font-family: "Montserrat", var(--font-sans);
    font-weight: 600;
    font-size: 1.28rem;
    color: var(--brown);
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .card__sizes { display: inline-flex; gap: 5px; flex-shrink: 0; }
  .card__bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-top: auto;
    margin-bottom: 16px;
  }
  .size-chip {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 21px;
    border-radius: 5px;
    background: var(--bg, var(--olive));
    color: var(--fg, #fff);
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0;
  }

  .card__desc {
    display: block;
    min-height: calc(6em - 30px);
    margin-top: 12px;
    font-size: 0.8rem;
    color: var(--brown);
  }
  .card__sub { display: block; margin-top: 0; font-size: calc(0.66rem + 2px); color: var(--muted); }
  .card__details {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 0;
    color: #452928;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    opacity: 0.72;
  }
  .card__details-arrow {
    display: inline-block;
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .card__head:hover .card__details,
  .card__head:focus-visible .card__details { opacity: 1; }
  .card__head:hover .card__details-arrow,
  .card__head:focus-visible .card__details-arrow { transform: translateX(4px); }

  /* expand */
  .card__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--dur) var(--ease);
  }
  .card__panel-inner {
    overflow: hidden;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .card__head[aria-expanded="true"] + .card__panel { grid-template-rows: 1fr; }
  .card__head[aria-expanded="true"] + .card__panel .card__panel-inner { opacity: 1; transform: none; }

  .detail {
    display: flex;
    flex-direction: column;
    padding: 4px 20px 22px;
    border-top: 1px solid var(--hairline);
    margin: 0 4px;
  }
  .card__panel-inner { background: var(--cream-hero); }
  .detail__h {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--olive-dark); margin-top: 16px; margin-bottom: 8px;
  }
  .sizes { display: flex; flex-direction: column; gap: 8px; }
  .size { display: flex; justify-content: space-between; align-items: center; gap: 12px; font-size: 0.86rem; }
  .size__label { display: flex; align-items: center; gap: 8px; color: var(--brown); flex-wrap: wrap; }
  .size__code {
    display: inline-grid; place-items: center;
    width: 20px; height: 20px; border-radius: 5px;
    background: var(--bg); color: var(--fg);
    font-size: 0.66rem; font-weight: 600; line-height: 1;
  }
  .size__note { display: block; width: 100%; font-size: 0.7rem; color: var(--muted); font-style: normal; padding-left: 28px; }
  .size__price { color: var(--brown); font-weight: 600; white-space: nowrap; }

  .detail__allergens { font-size: 0.82rem; color: var(--brown); }

  .detail__storage { font-size: 0.8rem; color: var(--muted); line-height: 1.55; }
  .detail__cta { margin-top: 18px; width: 100%; height: 46px; font-size: 0.9rem; }

  .card.is-hidden { display: none; }

</style>
