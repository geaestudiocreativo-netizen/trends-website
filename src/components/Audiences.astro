---
// SERVICES — static rows on the light band, per the FINAL Home Page frames
// (Desktop | Home Page and Mobile | Home Page now share this layout).
// Row: LABEL — short descriptor.
import { audiences } from "../data/audiences";
---
<section class="section audiences-section" aria-labelledby="audiences-title">
  <div class="container">
    <h2 class="sr-only" id="audiences-title">Para quiénes</h2>
    <ul class="audiences__list">
      {audiences.map((a) => (
        <li class="aud">
          <span class="aud__label">{a.label}</span>
          <span class="aud__dash" aria-hidden="true">—</span>
          <span class="aud__short">{a.short}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .audiences-section {
    background: var(--cream-hero);
    padding-block: clamp(40px, 7vw, 92px);
  }
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .audiences__list {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.8vw, 26px);
  }
  .aud {
    display: grid;
    grid-template-columns: minmax(0, 240px) auto minmax(0, 1fr);
    align-items: baseline;
    gap: clamp(10px, 1.6vw, 22px);
  }
  .aud__label {
    font-size: clamp(0.9rem, 1.5vw, 1.32rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--brown);
    line-height: 1.2;
  }
  .aud__dash { color: var(--brown); line-height: 1.2; }
  .aud__short {
    font-size: clamp(0.8rem, 1.1vw, 1rem);
    letter-spacing: 0.06em;
    color: var(--brown);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .aud {
      grid-template-columns: minmax(0, auto) auto minmax(0, 1fr);
      gap: 8px;
    }
    .aud__short { letter-spacing: 0.02em; }
  }
</style>
